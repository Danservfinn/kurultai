aw/agents/main/scripts/task-consumer.sh\n-rw-------  1 kublai  staff   4793 Mar  3 19:56 /Users/kublai/.openclaw/agents/main/scripts/task-queue-monitor.py\n-rwx------  1 kublai  staff   2295 Mar  3 09:53 /Users/kublai/.openclaw/agents/main/scripts/task-queue-write.sh\n-rwx------  1 kublai  staff  14150 Mar  4 16:10 /Users/kublai/.openclaw/agents/main/scripts/task-router.py\n-rwx------  1 kublai  staff   8016 Mar  4 13:25 /Users/kublai/.openclaw/agents/main/scripts/task-watcher.py","cwd":"/Users/kublai/.openclaw/agents/main"},"isError":false,"timestamp":1772703272458}}
{"type":"message","id":"39ff64eb","parentId":"e77772d3","timestamp":"2026-03-05T09:34:32.470Z","message":{"role":"toolResult","toolCallId":"call_9fd80096633244da9eaf162f","toolName":"exec","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nHeartbeat Task Executor\n\nExecutes pending agent tasks during heartbeat cycles.\nCalled by heartbeat-watchdog cron job every 5 minutes.\n\nUsage:\n    python3 scripts/heartbeat-task-executor.py [--agent <agent>] [--timeout <seconds>]\n\"\"\"\n\nimport os\nimport sys\nimport subprocess\nimport time\nfrom pathlib import Path\nfrom datetime import datetime\n\n# Configuration\nAGENTS_DIR = Path(\"/Users/kublai/.openclaw/agents/main/agent\")\nTIMEOUT_DEFAULT = 240  # 4 minutes (heartbeat runs every 5 min)\n\ndef list_pending_tasks(agent_dir):\n    \"\"\"List pending tasks for an agent, sorted by priority.\"\"\"\n    tasks_dir = agent_dir / \"tasks\"\n    if not tasks_dir.exists():\n        return []\n    \n    pending = []\n    for f in tasks_dir.glob(\"*.md\"):\n        # Skip completed/executing tasks\n        if any(x in f.name for x in ['.executing', '.completed', '.done']):\n            continue\n        pending.append(f)\n    \n    # Sort by priority: high-* > normal-* > low-*\n    def priority_key(path):\n        name = path.name.lower()\n        if name.startswith('high-'):\n            return (0, path.stat().st_mtime)\n        elif name.startswith('normal-'):\n            return (1, path.stat().st_mtime)\n        elif name.startswith('low-'):\n            return (2, path.stat().st_mtime)\n        return (3, path.stat().st_mtime)\n    \n    return sorted(pending, key=priority_key)\n\ndef execute_task(task_file, timeout):\n    \"\"\"Execute a single task file. Returns (success, output).\"\"\""}],"details":{"status":"completed","exitCode":0,"durationMs":6,"aggregated":"#!/usr/bin/env python3\n\"\"\"\nHeartbeat Task Executor\n\nExecutes pending agent tasks during heartbeat cycles.\nCalled by heartbeat-watchdog cron job every 5 minutes.\n\nUsage:\n    python3 scripts/heartbeat-task-executor.py [--agent <agent>] [--timeout <seconds>]\n\"\"\"\n\nimport os\nimport sys\nimport subprocess\nimport time\nfrom pathlib import Path\nfrom datetime import datetime\n\n# Configuration\nAGENTS_DIR = Path(\"/Users/kublai/.openclaw/agents/main/agent\")\nTIMEOUT_DEFAULT = 240  # 4 minutes (heartbeat runs every 5 min)\n\ndef list_pending_tasks(agent_dir):\n    \"\"\"List pending tasks for an agent, sorted by priority.\"\"\"\n    tasks_dir = agent_dir / \"tasks\"\n    if not tasks_dir.exists():\n        return []\n    \n    pending = []\n    for f in tasks_dir.glob(\"*.md\"):\n        # Skip completed/executing tasks\n        if any(x in f.name for x in ['.executing', '.completed', '.done']):\n            continue\n        pending.append(f)\n    \n    # Sort by priority: high-* > normal-* > low-*\n    def priority_key(path):\n        name = path.name.lower()\n        if name.startswith('high-'):\n            return (0, path.stat().st_mtime)\n        elif name.startswith('normal-'):\n            return (1, path.stat().st_mtime)\n        elif name.startswith('low-'):\n            return (2, path.stat().st_mtime)\n        return (3, path.stat().st_mtime)\n    \n    return sorted(pending, key=priority_key)\n\ndef execute_task(task_file, timeout):\n    \"\"\"Execute a single task file. Returns (success, output).\"\"\"","cwd":"/Users/kublai/.openclaw/agents/main"},"isError":false,"timestamp":1772703272469}}
