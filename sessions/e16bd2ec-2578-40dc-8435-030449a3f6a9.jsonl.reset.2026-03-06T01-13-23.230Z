  - link \"Subscribe\" [ref=e20] [cursor=pointer]:\n              - /url: /auth/signup\n    - main [ref=e21]:\n      - generic [ref=e24]:\n        - generic [ref=e25]:\n          - generic [ref=e26]:\n            - generic [ref=e27]:\n              - img [ref=e28]\n              - heading \"Parse for Agents\" [level=1] [ref=e30]\n            - paragraph [ref=e31]: Test and evaluate LLM prompts. Get quality scores, cost analysis, and latency metrics.\n          - generic [ref=e32]: MVP\n        - generic [ref=e33]:\n          - generic [ref=e35]:\n            - generic [ref=e36]:\n              - generic [ref=e37]: Prompt Configuration\n              - generic [ref=e38]:\n                - text: Use\n                - code [ref=e39]: \"{{input}}\"\n                - text: for variable interpolation.\n            - generic [ref=e40]:\n              - generic [ref=e41]:\n                - text: Prompt Template\n                - textbox \"Prompt Template\" [ref=e42]:\n                  - /placeholder: Enter your prompt template...\n                  - text: \"Summarize the following article in 3 bullet points: {{input}}\"\n              - generic [ref=e43]:\n                - generic [ref=e44]:\n                  - text: Model\n                  - combobox [ref=e45] [cursor=pointer]:\n                    - generic: DeepSeek V3\n                    - img [ref=e46]\n                - generic [ref=e48]:\n                  - text: Est. Cost\n                  - generic [ref=e49]: ~$0.0002\n              - generic [ref=e50]:\n                - text: Test Input\n                - textbox \"Test Input\" [ref=e51]:\n                  - /placeholder: Enter test input text...\n                  - text: The Federal Reserve announced today that it would keep interest rates unchanged, citing ongoing concerns about inflation. This decision marks the third consecutive meeting where rates have been held steady.\n              - generic [ref=e52]:\n                - text: Expected Output (optional)\n                - textbox \"Expected Output (optional)\" [ref=e53]:\n                  - /placeholder: Describe what the output should contain...\n              - generic [ref=e54]:\n                - text: Evaluators\n                - generic [ref=e55]:\n                  - generic [ref=e56]:\n                    - checkbox \"quality\" [checked] [ref=e57] [cursor=pointer]:\n                      - generic:\n                        - img\n                    - generic [ref=e58] [cursor=pointer]: quality\n                  - generic [ref=e59]:\n                    - checkbox \"cost\" [checked] [ref=e60] [cursor=pointer]:\n                      - generic:\n                        - img\n                    - generic [ref=e61] [cursor=pointer]: cost\n                  - generic [ref=e62]:\n                    - checkbox \"latency\" [checked] [ref=e63] [cursor=pointer]:\n                      - generic:\n                        - img\n                    - generic [ref=e64] [cursor=pointer]: latency\n                  - generic [ref=e65]:\n                    - checkbox \"injection_safety\" [ref=e66] [cursor=pointer]\n                    - generic [ref=e67] [cursor=pointer]: injection_safety\n              - generic [ref=e68]:\n                - generic [ref=e69]:\n                  - text: Temperature\n                  - spinbutton \"Temperature\" [ref=e70]: \"0.7\"\n                - generic [ref=e71]:\n                  - text: Max Tokens\n                  - spinbutton \"Max Tokens\" [ref=e72]: \"1024\"\n              - link \"Sign in to Run Evaluations\" [ref=e73] [cursor=pointer]:\n                - /url: /auth/signin\n                - button \"Sign in to Run Evaluations\" [ref=e74]:\n                  - img\n                  - text: Sign in to Run Evaluations\n          - generic [ref=e75]:\n            - generic [ref=e76]:\n              - generic [ref=e78]: API Endpoints\n              - generic [ref=e79]:\n                - generic [ref=e80]