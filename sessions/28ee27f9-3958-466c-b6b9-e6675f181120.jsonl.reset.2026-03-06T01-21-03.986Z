. Large numbers should have grouped digits (e.g., 42,000) or be in scientific or metric notation (4.2e+4, 42k). Currencies should have fixed precision ($3.50). Reported numerical results should be rounded to significant digits (4021 becomes 4000). Number formats should appropriate to the reader’s locale (42.000,00 or 42,000.00). The list goes on.\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/schemas.ts:function handleObjectResult(result: ParsePayload, final: ParsePayload, key: PropertyKey) {\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/schemas.ts:function handleOptionalObjectResult(result: ParsePayload, final: ParsePayload, key: PropertyKey, input: any) {\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/schemas.ts:          payload.value[keyResult.value as PropertyKey] = keyResult.value;\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/schemas.ts:              payload.value[keyResult.value as PropertyKey] = result.value;\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/schemas.ts:          payload.value[keyResult.value as PropertyKey] = result.value;\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/checks.ts:    payload.issues.push(...util.prefixIssues(property, result.issues));\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/checks.ts:          value: (payload.value as any)[def.property],\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/checks.ts:        return result.then((result) => handleCheckPropertyResult(result, payload, def.property));\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/checks.ts:      handleCheckPropertyResult(result, payload, def.property);\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/core/util.ts:  float32: [-3.4028234663852886e38, 3.4028234663852886e38],\n/Users/kublai/projects/parse-github/node_modules/zod/src/v4/mini/tests/number.test.ts:  // -3.4028234663852886e38