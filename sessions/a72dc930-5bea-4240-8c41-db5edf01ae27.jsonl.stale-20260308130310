rd in result:\n            results.append(dict(record))\n    \n    driver.close()\n    return results\n\ndef generate_report(goals):\n    now = datetime.now()\n    report_lines = [f\"📊 Daily Progress {now.strftime('%Y-%m-%d')}\"]\n    report_lines.append(\"\")\n    \n    for goal in goals:\n        name = goal.get('name', 'Unnamed Goal')\n        total = goal.get('total_tasks', 0) or 0\n        completed = goal.get('completed', 0) or 0\n        in_progress = goal.get('in_progress', 0) or 0\n        blocked = goal.get('blocked', 0) or 0\n        \n        # Calculate percentage\n        if total > 0:\n            pct = int((completed / total) * 100)\n        else:\n            pct = 0\n        \n        # Calculate days remaining\n        deadline = goal.get('deadline')\n        if deadline:\n            try:\n                if hasattr(deadline, 'to_native'):\n                    deadline_dt = deadline.to_native()\n                else:\n                    deadline_dt = deadline\n                days_remaining = (deadline_dt - now).days\n            except:\n                days_remaining = \"N/A\"\n        else:\n            days_remaining = \"Ongoing\"\n        \n        # Check for blockers (>48h no progress)\n        last_progress = goal.get('last_progress')\n        blockers = []\n        if blocked > 0:\n            blockers.append(f\"{blocked} blocked tasks\")\n        if last_progress:\n            try:\n                if hasattr(last_progress, 'to_native'):\n                    last_dt = last_progress.to_native()\n                else:\n                    last_dt = last_progress\n                hours_since = (now - last_dt).total_seconds() / 3600\n                if hours_since > 48:\n                    blockers.append(f\"No progress in {int(hours_since)}h\")\n            except:\n                pass\n        \n        # Revenue metrics for Parse goal\n        revenue_info = \"\"\n        if 'parse' in name.lower() or 'revenue' in name.lower():\n     