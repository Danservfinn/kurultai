{"type":"message","id":"6d9afa19","parentId":"89e713f8","timestamp":"2026-03-03T16:06:37.186Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to update the heartbeat handlers to write to the spawn queue instead of just logging. Let me update the temujin_task_pickup handler.","thinkingSignature":"reasoning_content"},{"type":"text","text":"Now let me update the heartbeat handlers to write spawn requests:\n\n"},{"type":"toolCall","id":"call_c9dad2588f1542c0837383d7","name":"edit","arguments":{"path":"/Users/kublai/kurultai/kublai-repo/tools/kurultai/agent_tasks.py","oldText":"async def temujin_task_pickup(driver) -> Dict:\n    \"\"\"\n    Check for pending tasks in temujin task queue.\n\n    Polls the file-based task queue and spawns agents to execute tasks.\n    \"\"\"\n    import glob\n    import os\n    import subprocess\n\n    task_dir = \"/Users/kublai/.openclaw/agents/main/agent/temujin/tasks\"\n\n    results = {\n        \"tasks_found\": 0,\n        \"tasks_spawned\": 0,\n        \"tokens_used\": 100\n    }\n\n    if not os.path.exists(task_dir):\n        return {\"summary\": \"No task directory found\", \"tokens_used\": 50, \"data\": results}\n\n    # Find pending tasks\n    try:\n        tasks = (glob.glob(f\"{task_dir}/high-*.md\") +\n                 glob.glob(f\"{task_dir}/normal-*.md\") +\n                 glob.glob(f\"{task_dir}/low-*.md\"))\n        results[\"tasks_found\"] = len(tasks)\n\n        if not tasks:\n            return {\"summary\": \"No pending tasks\", \"tokens_used\": 50, \"data\": results}\n\n        # Process each task - spawn agent and move to executing\n        for task_file in tasks:\n            task_name = os.path.basename(task_file)\n            # Read task description\n            with open(task_file, 'r') as f:\n                content = f.read()\n                # Extract task description\n                import re\n                match = re.search(r'^# Task: (.+)$', content, re.MULTILINE)\n                task_desc = match.group(1) if match else task_name\n\n            # Log what would be spawned\n            logger.info(f\"Temujin task pickup: Would spawn agent for '{task_desc}'\")\n\n            # Move to executing\n            executing_file = task_file.replace('.md', '.executing.md')\n            os.rename(task_file, executing_file)\n\n            results[\"tasks_spawned\"] += 1\n\n        return {\n            \"summary\": f\"Found {results['tasks_found']} tasks, marked {results['tasks_spawned']} for execution\",\n            \"tokens_used\": 200,\n            \"data\": results\n        }\n\n    except Exception as e:\n        logger.exception(\"Temujin task pickup failed\")\n        return {\"summary\": f\"Error: {e}\", \"tokens_used\": 100, \"data\": {\"error\": str(e)}}","newText":"async def temujin_task_pickup(driver) -> Dict:\n    \"\"\"\n    Check for pending tasks in temujin task queue.\n\n    Polls the file-based task queue and writes spawn requests.\n    \"\"\"\n    import glob\n    import json\n    import os\n    import time\n\n    task_dir = \"/Users/kublai/.openclaw/agents/main/agent/temujin/tasks\"\n    spawn_queue = \"/Users/kublai/.openclaw/agents/main/logs/spawn-queue.jsonl\"\n\n    results = {\n        \"tasks_found\": 0,\n        \"tasks_spawned\": 0,\n        \"tokens_used\": 100\n    }\n\n    if not os.path.exists(task_dir):\n        return {\"summary\": \"No task directory found\", \"tokens_used\": 50, \"data\": results}\n\n    # Find pending tasks\n    try:\n        tasks = (glob.glob(f\"{task_dir}/high-*.md\") +\n                 glob.glob(f\"{task_dir}/normal-*.md\") +\n                 glob.glob(f\"{task_dir}/low-*.md\"))\n        results[\"tasks_found\"] = len(tasks)\n\n        if not tasks:\n            return {\"summary\": \"No pending tasks\", \"tokens_used\": 50, \"data\": results}\n\n        # Process each task - write spawn request and move to executing\n        for task_file in tasks:\n            task_name = os.path.basename(task_file)\n            # Read task description\n            with open(task_file, 'r') as f:\n                content = f.read()\n                import re\n                match = re.search(r'^# Task: (.+)$', content, re.MULTILINE)\n                task_desc = match.group(1) if match else task_name\n\n            # Write spawn request to queue\n            spawn_request = {\n                \"agent\": \"temujin\",\n                \"task\": task_desc,\n                \"model\": \"qwen3.5-plus\",\n                \"label\": f\"temujin-{int(time.time())}\",\n                \"source\": \"task_pickup\",\n                \"source_file\": task_name\n            }\n\n            with open(spawn_queue, 'a') as f:\n                f.write(json.dumps(spawn_request) + '\\n')\n\n            logger.info(f\"Temujin spawn request queued: {task_desc}\")\n\n            # Move to executing\n            executing_file = task_file.replace('.md', '.executing.md')\n            os.rename(task_file, executing_file)\n\n            results[\"tasks_spawned\"] += 1\n\n        return {\n            \"summary\": f\"Found {results['tasks_found']} tasks, queued {results['tasks_spawned']} spawns\",\n            \"tokens_used\": 200,\n            \"data\": results\n        }\n\n    except Exception as e:\n        logger.exception(\"Temujin task pickup failed\")\n        return {\"summary\": f\"Error: {e}\", \"tokens_used\": 100, \"data\": {\"error\": str(e)}}"}}],"api":"openai-completions","provider":"bailian","model":"qwen3.5-plus","usage":{"input":106959,"output":1331,"cacheRead":0,"cacheWrite":0,"totalTokens":108290,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772553861960}}
