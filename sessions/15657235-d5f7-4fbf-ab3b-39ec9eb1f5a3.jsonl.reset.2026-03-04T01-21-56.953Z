for s in spawns if s.get('status') == 'ready']\n+ 68 log(f\"Found {len(ready)} ready spawn(s)\")\n  47 \n- 48 # Output spawn commands for each ready spawn\n- 49 for s in spawns:\n- 50     if s.get('status') == 'ready':\n- 51         agent = s.get('agent', 'unknown')\n- 52         task = s.get('task', '')\n- 53         model = s.get('model', 'qwen3.5-plus')\n- 54         label = s.get('label', 'unknown')\n- 55         \n- 56         log(f\"SPAWN: {agent} ({model}) - {label}\")\n- 57         print(f\"SPAWN_CMD|{agent}|{model}|{label}|{task}\")\n- 58         \n- 59         # Mark as processing\n- 60         s['status'] = 'processing'\n+ 70 for s in ready:\n+ 71     agent = s.get('agent', 'unknown')\n+ 72     task = s.get('task', '')\n+ 73     model = s.get('model', 'qwen3.5-plus')\n+ 74     label = s.get('label', 'unknown')\n+ 75     mode = s.get('mode', 'run')\n+ 76     continuous = s.get('continuous', False)\n+ 77     retry_count = s.get('retry_count', 0)\n+ 78     \n+ 79     # Check if continuous task already running\n+ 80     if continuous and s.get('session_key'):\n+ 81         log(f\"SKIP: {label} (continuous task already running)\")\n+ 82         continue\n+ 83     \n+ 84     log(f\"SPAWN: {agent} ({model}, {mode}) - {label}\")\n+ 85     print(f\"SPAWN_CMD|{agent}|{model}|{label}|{task}|{mode}|{continuous}\")\n+ 86     \n+ 87     # Mark as running\n+ 88     s['status'] = 'running'\n+ 89     s['last_spawned'] = datetime.now().isoformat()\n  61 \n+ 91 # Handle failed spawns (retry logic)\n+ 92 failed = [s for s in spawns if s.get('status') == 'failed']\n+ 93 for s in failed:\n+ 94     retry_count = s.get('retry_count', 0)\n+ 95     max_retries = s.get('max_retries', 3)\n+ 96     label = s.get('label', 'unknown')\n+ 97     \n+ 98     if retry_count < max_retries:\n+ 99         # Retry\n+100         s['retry_count'] = retry_count + 1\n+101         s['status'] = 'ready'\n+102         s['last_retry'] = datetime.now().isoformat()\n+103         s['error'] = f\"Retry {retry_count + 1}/{max_retries}\"\n+104         log(f\"RETRY: {label} (attempt {retry_count + 1}/{max_retries})\")\n+105     else:\n+106         # Dead letter\n+107         add_to_dead_letter(s)\n+108         spawns.remove(s)\n+109         log(f\"FAILED: {label} (max retries exceeded)\")\n+110 \n+111 # Cleanup completed spawns older than 1 hour\n+112 cutoff = datetime.now().timestamp() - 3600\n+113 spawns = [s for s in spawns if \n+114           s.get('status') not in ['completed', 'failed'] or\n+115           s.get('completed_at') is None or\n+116           datetime.fromisoformat(s.get('completed_at', '2000-01-01')).timestamp() > cutoff]\n+117 \n  62 # Save updated queue\n- 63 with open(SPAWN_QUEUE, 'w') as f:\n- 64     json.dump({'spawns': spawns, 'updated': datetime.now().timestamp()}, f, indent=2)\n+119 save_queue({'spawns': spawns, 'updated': datetime.now().timestamp()})\n  65 \n- 66 log(f\"Processed {sum(1 for s in spawns if s.get('status') == 'processing')} spawns\")\n+121 log(f\"Processed {len(ready)} spawns, {len(failed)} retries, {len(spawns)} remaining in queue\")\n  67 PYTHON_SCRIPT\n  68 \n  69 log \"=== Cycle Complete ===\"","firstChangedLine":29},"isError":false,"timestamp":1772560742060}}
{"type":"message","id":"ad376d71","parentId":"c4a52ecf","timestamp":"2026-03-03T17:59:10.590Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to create a task completion handler that agents can call when they finish. This will update the queue with completion status.\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"Now create a task completion handler:\n\n"},{"type":"toolCall","id":"call_fdfbca2a544640a382c4fa7b","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nTask Completion Handler - Called by agents when they finish\n\nUsage:\n    python3 complete-task.py <label> <status> [error_message]\n    \nStatus: completed, failed, killed\n\"\"\"\n\nimport json\nimport os\nimport sys\nfrom datetime import datetime\n\nSPAWN_QUEUE = \"/Users/kublai/.openclaw/agents/main/logs/spawn-pending.json\"\nCOMPLETION_LOG = \"/Users/kublai/.openclaw/agents/main/logs/task-completions.jsonl\"\n\ndef log_completion(label, status, error=None, session_key=None):\n    \"\"\"Log task completion\"\"\"\n    os.makedirs(os.path.dirname(COMPLETION_LOG), exist_ok=True)\n    entry = {\n        \"label\": label,\n        \"status\": status,\n        \"error\": error,\n        \"session_key\": session_key,\n        \"completed_at\": datetime.now().isoformat()\n    }\n    with open(COMPLETION_LOG, 'a') as f:\n        f.write(json.dumps(entry) + '\\n')\n\ndef update_queue(label, status, error=None):\n    \"\"\"Update spawn queue with completion status\"\"\"\n    if not os.path.exists(SPAWN_QUEUE):\n        return False\n    \n    try:\n        with open(SPAWN_QUEUE, 'r') as f:\n            data = json.load(f)\n    except:\n        return False\n    \n    spawns = data.get('spawns', [])\n    updated = False\n    \n    for s in spawns:\n        if s.get('label') == label:\n            # Skip continuous tasks (they never complete)\n            if s.get('continuous'):\n                print(f\"Task {label} is continuous - not marking complete\")\n                return False\n            \n            s['status'] = status\n            s['completed_at'] = datetime.now().isoformat()\n            if error:\n                s['error'] = error\n            \n            updated = True\n            print(f\"Updated {label} → {status}\")\n            break\n    \n    if updated:\n        with open(SPAWN_QUEUE, 'w') as f:\n            json.dump({'spawns': spawns, 'updated': datetime.now().timestamp()}, f, indent=2)\n    \n    return updated\n\ndef main():\n    if len(sys.argv) < 3:\n        print(\"Usage: complete-task.py <label> <status> [error_message]\")\n        print(\"Status: completed, failed, killed\")\n        sys.exit(1)\n    \n    label = sys.argv[1]\n    status = sys.argv[2]\n    error = sys.argv[3] if len(sys.argv) > 3 else None\n    \n    # Validate status\n    if status not in ['completed', 'failed', 'killed']:\n        print(f\"Invalid status: {status}\")\n        print(\"Valid: completed, failed, killed\")\n        sys.exit(1)\n    \n    # Update queue\n    queue_updated = update_queue(label, status, error)\n    \n    # Log completion\n    log_completion(label, status, error)\n    \n    if queue_updated:\n        print(f\"✓ Task {label} marked as {status}\")\n    else:\n        print(f\"⚠ Task {label} not found in queue (may already be cleaned up)\")\n\nif __name__ == \"__main__\":\n    main()\n","path":"/Users/kublai/.openclaw/agents/main/scripts/complete-task.py"}}],"api":"openai-completions","provider":"bailian","model":"qwen3.5-plus","usage":{"input":160267,"output":834,"cacheRead":0,"cacheWrite":0,"totalTokens":161101,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772560742077}}
