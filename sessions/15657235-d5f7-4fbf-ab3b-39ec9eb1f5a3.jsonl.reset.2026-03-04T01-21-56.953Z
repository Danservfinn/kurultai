ss to avoid import issues\n    result = subprocess.run(\n        ['python3', f'{SCRIPTS_DIR}/task-router.py', '--classify', 'Build a login feature for Parse'],\n        capture_output=True,\n        text=True,\n        timeout=5\n    )\n    \n    output = json.loads(result.stdout)\n    assert output['destination'] == 'temujin', f\"Expected temujin, got {output['destination']}\"\n    \n    # Test research task\n    result = subprocess.run(\n        ['python3', f'{SCRIPTS_DIR}/task-router.py', '--classify', 'Research competitor pricing'],\n        capture_output=True,\n        text=True,\n        timeout=5\n    )\n    output = json.loads(result.stdout)\n    assert output['destination'] == 'mongke', f\"Expected mongke, got {output['destination']}\"\n    \n    # Test writing task\n    result = subprocess.run(\n        ['python3', f'{SCRIPTS_DIR}/task-router.py', '--classify', 'Write a blog post about AI'],\n        capture_output=True,\n        text=True,\n        timeout=5\n    )\n    output = json.loads(result.stdout)\n    assert output['destination'] == 'chagatai', f\"Expected chagatai, got {output['destination']}\""}}],"api":"openai-completions","provider":"bailian","model":"qwen3.5-plus","usage":{"input":359231,"output":761,"cacheRead":0,"cacheWrite":0,"totalTokens":359992,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772580079826}}
