{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kurultai.local/buildroom/schemas/operator-summary.schema.json",
  "title": "operator-summary",
  "type": "object",
  "required": [
    "summary_id",
    "room_id",
    "generated_at",
    "headline",
    "status",
    "current_owner",
    "latest_artifacts",
    "operator_needs_to_know",
    "operator_decisions_needed",
    "links"
  ],
  "additionalProperties": false,
  "properties": {
    "summary_id": {
      "type": "string"
    },
    "room_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "headline": {
      "type": "string"
    },
    "status": {
      "enum": [
        "candidate",
        "planned",
        "building",
        "verifying",
        "clean",
        "watch",
        "investigate",
        "parked"
      ]
    },
    "current_owner": {
      "type": "string"
    },
    "latest_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operator_needs_to_know": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operator_decisions_needed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
