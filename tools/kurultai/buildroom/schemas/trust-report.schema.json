{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kurultai.local/buildroom/schemas/trust-report.schema.json",
  "title": "trust-report",
  "type": "object",
  "required": [
    "trust_id",
    "room_id",
    "generated_at",
    "state",
    "reasons",
    "risk_score",
    "open_questions",
    "required_followups",
    "safe_to_archive"
  ],
  "additionalProperties": false,
  "properties": {
    "trust_id": {
      "type": "string"
    },
    "room_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "state": {
      "enum": [
        "clean",
        "watch",
        "investigate"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_score": {
      "type": "number"
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_followups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safe_to_archive": {
      "type": "boolean"
    }
  }
}
