// OpenClaw Gateway Configuration for Kurultai — Mac Mini Production
// Host: kublai.local (100.69.84.64) via Cloudflare tunnel at kublai.kurult.ai
// Version: 2026.3.8
// Synced from Mac Mini 2026-03-14, secrets replaced with ${VAR} placeholders
{
  meta: {
    lastTouchedVersion: "2026.3.8",
    lastTouchedAt: "2026-03-13T20:29:53.194Z",
  },

  // Environment — shellEnv disabled to prevent leaking secrets to agent sandboxes
  env: {
    shellEnv: { enabled: false },
  },

  wizard: {
    lastRunAt: "2026-03-10T04:35:43.415Z",
    lastRunVersion: "2026.3.8",
    lastRunCommand: "doctor",
    lastRunMode: "local",
  },

  logging: {
    file: "/Users/kublai/.openclaw/logs/openclaw.log",
    consoleLevel: "info",
  },

  // ==========================================================================
  // MODEL PROVIDERS
  // mode: "merge" combines built-in providers with custom ones
  // All costs: 0 for free-tier providers (zai-coding, bailian, local, ollama)
  // ==========================================================================
  models: {
    mode: "merge",
    providers: {
      // Anthropic — direct API (requires ANTHROPIC_API_KEY, not currently used for routing)
      anthropic: {
        baseUrl: "https://api.anthropic.com",
        api: "anthropic-messages",
        models: [
          { id: "claude-opus-4-6", name: "Claude Opus 4.6", reasoning: true, input: ["text","image"], cost: { input: 15, output: 75, cacheRead: 1.5, cacheWrite: 15 }, contextWindow: 200000, maxTokens: 8192 },
          { id: "claude-sonnet-4-6", name: "Claude Sonnet 4.6", reasoning: false, input: ["text","image"], cost: { input: 3, output: 15, cacheRead: 0.3, cacheWrite: 3 }, contextWindow: 200000, maxTokens: 8192 },
          { id: "claude-haiku-4-5", name: "Claude Haiku 4.5", reasoning: false, input: ["text","image"], cost: { input: 1, output: 5, cacheRead: 0.1, cacheWrite: 1 }, contextWindow: 200000, maxTokens: 8192 },
        ],
      },

      // Bailian (Alibaba DashScope) — Qwen, MiniMax, Kimi models via OpenAI-compatible API
      bailian: {
        baseUrl: "https://coding-intl.dashscope.aliyuncs.com/v1",
        apiKey: "${BAILIAN_API_KEY}",
        api: "openai-completions",
        models: [
          { id: "qwen3.5-plus", name: "qwen3.5-plus", reasoning: false, input: ["text","image"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 1000000, maxTokens: 65536 },
          { id: "qwen3-coder-next", name: "qwen3-coder-next", reasoning: false, input: ["text"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 262144, maxTokens: 65536 },
          { id: "qwen3-coder-plus", name: "qwen3-coder-plus", reasoning: false, input: ["text"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 1000000, maxTokens: 65536 },
          { id: "MiniMax-M2.5", name: "MiniMax-M2.5", reasoning: false, input: ["text"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 204800, maxTokens: 131072 },
          { id: "kimi-k2.5", name: "kimi-k2.5", reasoning: false, input: ["text","image"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 60000, maxTokens: 32768 },
        ],
      },

      // Local LM Studio instance (Mac Mini, port 1234)
      local: {
        baseUrl: "http://localhost:1234/v1",
        apiKey: "not-needed",
        api: "openai-completions",
        models: [
          { id: "local-model", name: "Local LLM (LM Studio)", reasoning: false, input: ["text"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 128000, maxTokens: 8192 },
        ],
      },

      // Ollama (Mac Mini, port 11434)
      ollama: {
        baseUrl: "http://localhost:11434/v1",
        apiKey: "not-needed",
        api: "openai-completions",
        models: [
          { id: "lukey03/qwen3.5-9b-abliterated-vision", name: "Qwen 3.5 9B Abliterated Vision (Ollama)", api: "openai-completions", reasoning: false, input: ["text","image"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 262144, maxTokens: 16384 },
        ],
      },

      // Z.AI Coding — Anthropic-compatible API, GLM models (primary provider for all agents)
      "zai-coding": {
        baseUrl: "https://api.z.ai/api/anthropic",
        apiKey: "${ZAI_CODING_API_KEY}",
        api: "anthropic-messages",
        models: [
          { id: "glm-5", name: "GLM-5 (Z.AI Coding)", reasoning: true, input: ["text","image"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 202752, maxTokens: 16384 },
          { id: "glm-4.7", name: "GLM-4.7 (Z.AI Coding)", reasoning: false, input: ["text"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 202752, maxTokens: 16384 },
          { id: "glm-4.5-air", name: "GLM-4.5-Air (Z.AI Coding)", reasoning: false, input: ["text"], cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 }, contextWindow: 131072, maxTokens: 8192 },
        ],
      },
    },
  },

  // ==========================================================================
  // AGENT CONFIGURATION
  // Primary model: zai-coding/glm-5 for all agents (unified, no per-agent overrides)
  // Fallback chain: bailian/qwen3.5-plus → ollama local
  // Tolui: local ollama model (Signal group responder)
  // ==========================================================================
  agents: {
    defaults: {
      model: {
        primary: "zai-coding/glm-5",
        fallbacks: [
          "bailian/qwen3.5-plus",
          "ollama/lukey03/qwen3.5-9b-abliterated-vision",
        ],
      },
      // All model IDs must be fully qualified (provider/model) to avoid routing ambiguity
      models: {
        "anthropic/claude-opus-4-6": {},
        "anthropic/claude-sonnet-4-6": {},
        "anthropic/claude-haiku-4-5": {},
        "bailian/qwen3.5-plus": {},
        "bailian/MiniMax-M2.5": {},
        "bailian/kimi-k2.5": {},
        "google-gemini-cli/gemini-3.1-pro-preview-customtools": { alias: "gemini-3.1-pro-preview-customtools" },
        "ollama/lukey03/qwen3.5-9b-abliterated-vision": { alias: "qwen3.5-9b-abliterated-vision" },
        "zai-coding/glm-5": {},
        "zai-coding/glm-4.7": {},
        "zai-coding/glm-4.5-air": {},
      },
      skipBootstrap: true,          // We manage workspace files — don't overwrite with templates
      bootstrapMaxChars: 50000,     // SOUL.md files are 20-35K chars; default 20K truncates
      compaction: { mode: "safeguard" },
      thinkingDefault: "medium",
      heartbeat: {
        every: "30m",
        target: "none",
        prompt: "Read HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If nothing needs attention, reply HEARTBEAT_OK.",
      },
    },

    // Kurultai 6-agent system + Tolui (Signal group responder)
    list: [
      { id: "main",     name: "Kublai",  workspace: "/Users/kublai/.openclaw/agents/main",     model: "zai-coding/glm-5", heartbeat: { every: "30m", target: "none" } },
      { id: "mongke",   name: "Möngke",  workspace: "/Users/kublai/.openclaw/agents/mongke",   model: "zai-coding/glm-5", heartbeat: { every: "30m", target: "none" } },
      { id: "chagatai", name: "Chagatai", workspace: "/Users/kublai/.openclaw/agents/chagatai", model: "zai-coding/glm-5", heartbeat: { every: "30m", target: "none" } },
      { id: "temujin",  name: "Temüjin",  workspace: "/Users/kublai/.openclaw/agents/temujin",  model: "zai-coding/glm-5", heartbeat: { every: "30m", target: "none" } },
      { id: "jochi",    name: "Jochi",    workspace: "/Users/kublai/.openclaw/agents/jochi",    model: "zai-coding/glm-5", heartbeat: { every: "30m", target: "none" } },
      { id: "ogedei",   name: "Ögedei",   workspace: "/Users/kublai/.openclaw/agents/ogedei",   model: "zai-coding/glm-5", heartbeat: { every: "30m", target: "none" } },
      // Tolui — local ollama model, bound to Signal group
      { id: "tolui",    name: "Tolui",    workspace: "/Users/kublai/.openclaw/agents/tolui",    model: "ollama/lukey03/qwen3.5-9b-abliterated-vision", heartbeat: { every: "30m", model: "ollama/lukey03/qwen3.5-9b-abliterated-vision", target: "none" } },
    ],
  },

  // ==========================================================================
  // TOOLS & AGENT-TO-AGENT
  // ==========================================================================
  tools: {
    // CRITICAL: Deny gateway tool to prevent agents from using config.patch
    // which overwrites controlUi settings and breaks webchat connections
    deny: ["gateway"],
    // Enable agent-to-agent communication across all 7 agents
    agentToAgent: {
      enabled: true,
      allow: ["main", "temujin", "chagatai", "jochi", "mongke", "ogedei", "tolui"],
    },
  },

  // Tolui bound to Signal group (family group chat)
  bindings: [
    {
      agentId: "tolui",
      match: {
        channel: "signal",
        peer: { kind: "group", id: "3rnF4F5GBUWiYRUFAfEBObgK6UfcVZe6uUiXtdPtP2w=" },
      },
    },
  ],

  // Command restrictions — prevent agents from modifying config at runtime
  commands: {
    native: "auto",
    nativeSkills: "auto",
    config: false,     // Block /config command
    restart: false,    // Block /restart command
    ownerDisplay: "raw",
  },

  // ==========================================================================
  // CHANNELS
  // Signal-only on Mac Mini (no Discord, no signal-cli autostart — uses system signal-cli)
  // ==========================================================================
  channels: {
    signal: {
      enabled: true,
      account: "+15165643945",
      cliPath: "signal-cli",    // System signal-cli (no autostart, no httpHost/httpPort)
      dmPolicy: "allowlist",
      allowFrom: [
        "uuid:4b5f6588-41a1-4683-938a-6a549ba0586e",
        "+19194133445",
        "+16624580725",
        "+19193375833",
        "+19196125574",
        "+19194129251",
        "+19196225060",
        "+19197934403",
      ],
      groupAllowFrom: ["BROemHVncLgSz8tReUKBz6V3BeDhDB0EXaJd+sRp6oA="],
      groupPolicy: "open",
    },
  },

  // ==========================================================================
  // GATEWAY
  // Local mode, LAN-bound, token auth
  // Exposed via Cloudflare tunnel at kublai.kurult.ai
  // ==========================================================================
  gateway: {
    port: 18789,
    mode: "local",
    bind: "lan",
    controlUi: {
      enabled: true,
      allowedOrigins: [
        "https://kublai.kurult.ai",
        "http://localhost:18789",
        "http://127.0.0.1:18789",
      ],
      // Mac Mini is local — no insecure auth or device auth bypass needed
      dangerouslyAllowHostHeaderOriginFallback: false,
      allowInsecureAuth: false,
      dangerouslyDisableDeviceAuth: false,
    },
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
    // IMPORTANT: OpenClaw does EXACT STRING match, NOT CIDR subnet matching
    trustedProxies: [
      "127.0.0.1",
      "100.64.0.1", "100.64.0.2", "100.64.0.3", "100.64.0.4",
      "100.64.0.5", "100.64.0.6", "100.64.0.7", "100.64.0.8",
      "100.64.0.9", "100.64.0.10", "100.64.0.11", "100.64.0.12",
      "100.64.0.13", "100.64.0.14", "100.64.0.15", "100.64.0.16",
    ],
  },

  // Skills — nano-banana-pro uses Gemini API key
  skills: {
    entries: {
      "nano-banana-pro": { apiKey: "${GEMINI_API_KEY}" },
    },
  },

  // Plugins — Signal + Google Gemini CLI auth
  plugins: {
    allow: ["signal", "google-gemini-cli-auth"],
    entries: {
      "google-gemini-cli-auth": { enabled: true },
    },
  },
}
