<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kurultai.coordination-sweeper</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/kublai/.openclaw/agents/main/shared-context/hermes-kublai/lock_sweeper.py</string>
    </array>

    <!-- Run once per minute -->
    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/kublai/.openclaw/logs/coordination-sweeper.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/kublai/.openclaw/logs/coordination-sweeper.err</string>

    <!-- Restart if it exits non-zero (e.g. DB lock contention) -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>55</integer>
</dict>
</plist>

