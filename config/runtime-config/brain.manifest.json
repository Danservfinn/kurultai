{
  "brain_root": "${BRAIN_ROOT}",
  "directories": [
    {
      "path": "queue",
      "purpose": "inbox and work queue artifacts"
    },
    {
      "path": "generated",
      "purpose": "generated summaries and reports"
    },
    {
      "path": "receipts",
      "purpose": "append-only operation receipts"
    },
    {
      "path": "docs/plans",
      "purpose": "durable plans"
    },
    {
      "path": "operations",
      "purpose": "operational runbooks and status"
    },
    {
      "path": "analyses",
      "purpose": "research and synthesis outputs"
    },
    {
      "path": "content",
      "purpose": "content operating system"
    },
    {
      "path": "content/artifacts",
      "purpose": "media and static artifacts"
    }
  ],
  "private_indexes": [
    "~/.brain-index/brain.db",
    "~/.kublai/brain-index-private/brain.db"
  ]
}
